{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/collect-trends",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/analyze-trends",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "*/30 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
