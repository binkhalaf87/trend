# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TrendZone

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Prisma) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_TREND_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_TREND_FORECAST_MODEL=gpt-4o
OPENAI_PERSONALIZATION_MODEL=gpt-4o-mini
OPENAI_INFLUENCER_MATCH_MODEL=gpt-4o-mini
OPENAI_CONTENT_FALLBACK_MODEL=gpt-4o-mini

# ─── Anthropic (لـ Content Generator) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ملاحظة: Claude 3.5 Sonnet أُعلن إيقافه في 13 أغسطس 2025 وتقاعده في 22 أكتوبر 2025،
# لذا الافتراضي هنا هو البديل المدعوم الحالي. يمكنك override إذا كنت تستخدم Snapshot مختلفاً.
ANTHROPIC_CONTENT_MODEL=claude-sonnet-4-20250514

# ─── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (يطابق SubscriptionPlan enum: STARTER / GROWTH / ENTERPRISE)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Social Scraping / Trend Sources ──────────────────────────────────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
GOOGLE_TRENDS_API_KEY=your-google-trends-api-key

# ─── Cron / Background Jobs ────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret-key
